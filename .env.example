# MongoDB
MONGO_URI=mongodb://streamverse:streamverse123@localhost:27017

# RabbitMQ
RABBITMQ_URL=amqp://streamverse:streamverse123@localhost:5672

# JWT
JWT_SECRET=streamverse_jwt_secret_change_in_production
JWT_REFRESH_SECRET=streamverse_refresh_secret_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Service Ports
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
VIDEO_SERVICE_PORT=3002
TRANSCODE_SERVICE_PORT=3003
STREAM_SERVICE_PORT=3004
CHANNEL_SERVICE_PORT=3005
INTERACTION_SERVICE_PORT=3006
SEARCH_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008

# FFmpeg (fallback if not in PATH)
FFMPEG_PATH=ffmpeg

# Storage
UPLOAD_DIR=./uploads
HLS_OUTPUT_DIR=./hls-output

# Client
CLIENT_URL=http://localhost:5173
